# ===========================================
# Health SymptomSense - Environment Variables
# Copy to .env and customize for your environment
# ===========================================

# Flask
FLASK_APP=main.py
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=change-me-to-a-long-random-secret-key

# MongoDB
MONGODB_URI=mongodb://mongo:27017/
MONGODB_DB_NAME=health_symptomsense

# Redis (caching + rate limiting)
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=86400

# Rate Limiting
RATE_LIMIT_DEFAULT=200 per day;50 per hour
RATE_LIMIT_PREDICT=20 per minute

# Server
HOST=0.0.0.0
PORT=5000
APP_VERSION=3.0.0

# Monitoring
ENABLE_METRICS=1

# Gunicorn (production)
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
